# nginx HTTP Basic Auth credentials
# Generate a password hash:
#   openssl passwd -6
# Then create nginx/.htpasswd with the hash.
#
# Example .htpasswd entry:
#   admin:<hash>
#
# Mount the .htpasswd file at /etc/nginx/.htpasswd in the container.
# See docker-compose.yml for the volume mount configuration.

# getmfdata.com API key (for Vite dev server proxy)
# Get a free key at https://getmfdata.com
VITE_GETMFDATA_API_KEY=your_key_here
